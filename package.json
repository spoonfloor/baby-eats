{
  "name": "favorite-eats",
  "productName": "Baby Eats",
  "version": "1.0.0",
  "main": "electronMain.js",
  "scripts": {
    "start": "electron .",
    "build:web": "node scripts/buildWeb.js",
    "build:electron": "electron-builder",
    "dist": "npm run build:electron",
    "test:ingredient-display": "node tests/runIngredientDisplayTests.js",
    "test:ingredient-parser": "node tests/runIngredientPasteParserTests.js",
    "test:recipe-tags-keyboard": "node tests/runRecipeTagsKeyboardTests.js",
    "test:typeahead-keyboard": "node tests/runTypeaheadKeyboardTests.js",
    "test:unit-size-state": "node tests/runUnitSizeStateTests.js"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.spoonfloor.favoriteeats",
    "files": [
      "**/*",
      "!**/.venv/**"
    ],
    "mac": {
      "icon": "assets/app-icon.icns"
    },
    "win": {
      "icon": "assets/app-icon.ico"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.1"
  }
}
